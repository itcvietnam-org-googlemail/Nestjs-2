{
    "name": "angular",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "npm@11.9.0",
    "workspaces": [
        "src/apps/*",
        "src/packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev --filter=@app/*",
        "build": "turbo run build --filter=@app/*",
        "prod": "turbo run prod --filter=@app/*",
        "admin:dev": "turbo run dev --filter=@app/admin",
        "admin:build": "turbo run build --filter=@app/admin",
        "admin:prod": "turbo run prod --filter=@app/admin",
        "front:dev": "turbo run dev --filter=@app/front",
        "front:build": "turbo run build --filter=@app/front",
        "front:serve": "turbo run serve --filter=@app/front",
        "front:prod": "turbo run prod --filter=@app/front"
    },
    "dependencies": {
        "@angular/cdk": "^22.0.5",
        "@angular/common": "^22.0.0",
        "@angular/compiler": "^22.0.0",
        "@angular/core": "^22.0.0",
        "@angular/forms": "^22.0.0",
        "@angular/material": "^22.0.5",
        "@angular/platform-browser": "^22.0.0",
        "@angular/platform-server": "^22.0.0",
        "@angular/router": "^22.0.0",
        "@angular/ssr": "^22.0.6",
        "express": "^5.1.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^22.0.6",
        "@angular/cli": "^22.0.6",
        "@angular/compiler-cli": "^22.0.0",
        "@types/express": "^5.0.1",
        "@types/node": "^20.17.19",
        "ng-packagr": "^22.0.1",
        "typescript": "~6.0.2",
        "turbo": "^2.10.5"
    }
}